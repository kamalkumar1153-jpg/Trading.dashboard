name: Market Bot Live
on:
  schedule:
    - cron: '*/5 * * * *' # Har 5 minute mein chalega
  workflow_dispatch:      # Manual button ke liye
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - name: Install Python Libraries
        run: pip install requests pyrebase4
      - name: Run Market Bot
        env:
          FIREBASE_API_KEY: ${{ secrets.FIREBASE_API_KEY }}
          UPSTOX_ACCESS_TOKEN: ${{ secrets.UPSTOX_ACCESS_TOKEN }}
        run: python main.py
